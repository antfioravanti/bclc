# ---- 10. Plot 3: spatial reconstruction for each patch ----------------------
fill_patch <- function(X_patch, pred_idx, y_hat) {
v <- as.vector(X_patch); v[pred_idx] <- y_hat
matrix(v, nrow = nrow(X_patch), ncol = ncol(X_patch))
}
clip_to_range <- function(x, ref) {
rng <- range(ref, na.rm = TRUE); pmin(pmax(x, rng[1]), rng[2])
}
# Best m per patch (used to pick the corrected panel)
best_m_by_patch <- sapply(patch_data, function(pd) {
sub <- corr_df[corr_df$patch == pd$label, ]
sub$m[which.min(sub$rmse)]
})
names(best_m_by_patch) <- sapply(patch_data, `[[`, "label")
draw_patch_panels <- function() {
par(mfrow = c(n_patch, 4), mar = c(1, 1, 2.0, 1), oma = c(0, 0, 2, 0))
for (k in seq_len(n_patch)) {
pd <- patch_data[[k]]; lab <- pd$label
bm <- best_m_by_patch[[lab]]
X_masked <- pd$X_patch
X_masked[pd$pb$r1:pd$pb$r2, pd$pb$c1:pd$pb$c2] <- NA
X_naive <- fill_patch(pd$X_patch, pd$pred_idx,
clip_to_range(preds[[lab]][["naive"]], pd$X_patch))
X_corr  <- fill_patch(pd$X_patch, pd$pred_idx,
clip_to_range(preds[[lab]][[paste0("corr_m", bm)]],
pd$X_patch))
show_one <- function(M, ttl) {
image(t(M)[, nrow(M):1], col = heat_cols(),
main = ttl, xaxt = "n", yaxt = "n", asp = 1)
}
show_one(pd$X_patch, sprintf("%s: truth", lab))
show_one(X_masked,   "observed")
show_one(X_naive,    "naive (all lags)")
show_one(X_corr,     sprintf("corrected (m = %d)", bm))
}
mtext(sprintf("Reconstruction per patch -- image: %s", img_name),
outer = TRUE, cex = 1.1, font = 2)
}
ensure_plot_device()
draw_patch_panels()
png(file.path(out_dir, "spatial_reconstruction_all_patches.png"),
width = 12, height = 3 * n_patch, units = "in", res = 150)
draw_patch_panels()
dev.off()
cat("\nOutputs written to:", out_dir, "\n")
