#
# GLS mean:   mu_hat = (1' Sigma_OO^{-1} y_O) / (1' Sigma_OO^{-1} 1)
# Prediction: y_hat  = Sigma_PO Sigma_OO^{-1}(y_O - mu_hat 1) + mu_hat
ok_predict <- function(y_obs, Sigma, obs_idx, pred_idx, nugget = 1e-6) {
if (!is_psd(Sigma)) {
cat("  [warn] Sigma is not PSD (projecting onto PSD cone)\n")
}
Sigma_OO <- Sigma[obs_idx,  obs_idx,  drop = FALSE] +
nugget * diag(length(obs_idx))
Sigma_PO <- Sigma[pred_idx, obs_idx,  drop = FALSE]
RHS   <- cbind(y_obs, rep(1.0, length(obs_idx)))
Sol   <- solve(Sigma_OO, RHS)
alpha <- Sol[, 1L]
beta  <- Sol[, 2L]
mu_hat <- sum(alpha) / sum(beta)
as.vector(Sigma_PO %*% (alpha - mu_hat * beta) + mu_hat)
}
# ---- 2. Load image ----------------------------------------------------------
load("data/satellite-data.RData")
is_image <- vapply(data, function(x)
is.matrix(x) || (is.array(x) && length(dim(x)) == 2L), logical(1))
images   <- data[is_image]
img_idx  <- 3L
img_name <- names(images)[img_idx]
X_full   <- as.matrix(images[[img_idx]])
storage.mode(X_full) <- "double"
n1_img <- nrow(X_full); n2_img <- ncol(X_full)
cat(sprintf("Working with image '%s' (%d x %d)\n",
img_name, n1_img, n2_img))
# ---- 3. Define patches in different regions ---------------------------------
#
# Each patch has the same size so results are comparable across regions.
# Patch centers are placed in the four quadrants plus one centre patch.
patch_n1 <- 30L
patch_n2 <- 30L
pred_blk <- 8L
# Helper: patch specification by TOP-LEFT corner.
make_patch <- function(r1, c1, label) {
r2 <- r1 + patch_n1 - 1L
c2 <- c1 + patch_n2 - 1L
stopifnot(r1 >= 1L, r2 <= n1_img, c1 >= 1L, c2 <= n2_img)
list(label = label, r1 = r1, r2 = r2, c1 = c1, c2 = c2)
}
# Positions: roughly one per region. Adjust if needed for the specific image.
margin <- 8L
patches <- list(
make_patch(margin,                       margin,                       "top-left"),
make_patch(margin,                       n2_img - patch_n2 - margin + 1L, "top-right"),
make_patch(n1_img - patch_n1 - margin + 1L, margin,                       "bottom-left"),
make_patch(n1_img - patch_n1 - margin + 1L, n2_img - patch_n2 - margin + 1L, "bottom-right"),
make_patch((n1_img - patch_n1) %/% 2L + 1L, (n2_img - patch_n2) %/% 2L + 1L, "center")
)
n_patch <- length(patches)
cat(sprintf("Using %d patches of size %d x %d, hiding central %d x %d block.\n",
n_patch, patch_n1, patch_n2, pred_blk, pred_blk))
# ---- 4. Plot full image with patches overlaid -------------------------------
row_to_y <- function(r, nr) nr - r + 1L
plot_image_with_patches <- function(M, patches, pred_blk, title = "") {
nr <- nrow(M); nc <- ncol(M)
image(x = seq_len(nc), y = seq_len(nr), z = t(M)[, nr:1], col = heat_cols(),
main = title, xaxt = "n", yaxt = "n", asp = 1, useRaster = TRUE)
for (p in patches) {
# Patch outline (white)
rect(xleft   = p$c1 - 0.5,
ybottom = row_to_y(p$r2, nr) - 0.5,
xright  = p$c2 + 0.5,
ytop    = row_to_y(p$r1, nr) + 0.5,
border  = "white", lwd = 2)
# Prediction block (red)
pb_r1 <- p$r1 + (patch_n1 - pred_blk) %/% 2L
pb_c1 <- p$c1 + (patch_n2 - pred_blk) %/% 2L
pb_r2 <- pb_r1 + pred_blk - 1L
pb_c2 <- pb_c1 + pred_blk - 1L
rect(xleft   = pb_c1 - 0.5,
ybottom = row_to_y(pb_r2, nr) - 0.5,
xright  = pb_c2 + 0.5,
ytop    = row_to_y(pb_r1, nr) + 0.5,
border  = "#D73027", lwd = 2)
text(x = (p$c1 + p$c2) / 2,
y = row_to_y(p$r1, nr) + 2,
labels = p$label, col = "white", cex = 0.8, font = 2)
}
legend("topright",
legend = c("Patch", "Hidden block"),
col = c("white", "#D73027"),
lwd = 2, bty = "n", text.col = "white")
}
ensure_plot_device()
par(mfrow = c(1, 1), mar = c(1, 1, 3, 1))
plot_image_with_patches(X_full, patches, pred_blk,
title = sprintf("%s: %d patches", img_name, n_patch))
png(file.path(out_dir, "patches_overlay.png"),
width = 9, height = 9, units = "in", res = 150)
par(mfrow = c(1, 1), mar = c(1, 1, 3, 1))
plot_image_with_patches(X_full, patches, pred_blk,
title = sprintf("%s: %d patches", img_name, n_patch))
dev.off()
# ---- 5. Build covariance matrices once per patch ----------------------------
m_grid <- c(5L, 8L, 10L, 12L, 15L, 18L, 20L, 22L, 25L, 27L, 28L)
# For each patch, we build Sigma_naive and one Sigma_corr per m.
patch_data <- vector("list", n_patch)
for (k in seq_len(n_patch)) {
p <- patches[[k]]
cat(sprintf("\n-- Patch %d/%d (%s) --\n", k, n_patch, p$label))
X_patch <- X_full[p$r1:p$r2, p$c1:p$c2]
# Hidden block indices (column-major vec indexing)
pb_r1 <- (patch_n1 - pred_blk) %/% 2L + 1L; pb_r2 <- pb_r1 + pred_blk - 1L
pb_c1 <- (patch_n2 - pred_blk) %/% 2L + 1L; pb_c2 <- pb_c1 + pred_blk - 1L
pred_idx <- as.vector(outer(pb_r1:pb_r2, pb_c1:pb_c2,
FUN = function(r, c) (c - 1L) * patch_n1 + r))
obs_idx  <- setdiff(seq_len(patch_n1 * patch_n2), pred_idx)
y_all       <- as.vector(X_patch)
y_pred_true <- y_all[pred_idx]
y_obs       <- y_all[obs_idx]
# Naive Sigma
cat("  Sigma_naive ... "); tic()
Sigma_naive <- build_Sigma_naive(X_patch, Nh_normalize = TRUE)
#Sigma_naive <- psd_project(Sigma_naive)
toc()
# Bias-corrected Sigma for each m
sigma_corr <- vector("list", length(m_grid))
names(sigma_corr) <- as.character(m_grid)
for (mm in m_grid) {
cat(sprintf("  Sigma_corr (m = %2d) ... ", mm)); tic()
fit  <- bias_corrected_estimator(X_patch, m = mm, Nh_normalize = TRUE)
mats <- reshape_Sigma_hat_m(fit$Chat_star_m, fit$m, fit$n1, fit$n2)
#sigma_corr[[as.character(mm)]] <- psd_project(mats$Sigma_hat_m)
sigma_corr[[as.character(mm)]] <- mats$Sigma_hat_m
toc()
}
patch_data[[k]] <- list(
label       = p$label,
X_patch     = X_patch,
pb          = list(r1 = pb_r1, r2 = pb_r2, c1 = pb_c1, c2 = pb_c2),
pred_idx    = pred_idx,
obs_idx     = obs_idx,
y_pred_true = y_pred_true,
y_obs       = y_obs,
Sigma_naive = Sigma_naive,
sigma_corr  = sigma_corr
)
}
# ---- 6. Run kriging and collect RMSEs ---------------------------------------
results <- list()
preds   <- list()                                     # preds[[patch_label]][[key]]
for (k in seq_len(n_patch)) {
pd  <- patch_data[[k]]
lab <- pd$label
preds[[lab]] <- list()
# Naive
y_hat <- ok_predict(pd$y_obs, pd$Sigma_naive, pd$obs_idx, pd$pred_idx)
rmse  <- sqrt(mean((y_hat - pd$y_pred_true)^2))
results[[length(results) + 1L]] <- data.frame(
patch = lab, variant = "naive_full", m = NA_integer_, rmse = rmse,
stringsAsFactors = FALSE
)
preds[[lab]][["naive"]] <- y_hat
# Bias-corrected for each m
for (mm in m_grid) {
y_hat <- ok_predict(pd$y_obs,
pd$sigma_corr[[as.character(mm)]],
pd$obs_idx, pd$pred_idx)
rmse  <- sqrt(mean((y_hat - pd$y_pred_true)^2))
results[[length(results) + 1L]] <- data.frame(
patch = lab, variant = "corrected_m", m = mm, rmse = rmse,
stringsAsFactors = FALSE
)
preds[[lab]][[paste0("corr_m", mm)]] <- y_hat
}
}
res_df <- do.call(rbind, results); rownames(res_df) <- NULL
cat("\n============================================\n")
cat("  Ordinary kriging RMSE (by patch)\n")
cat("============================================\n")
print(res_df, row.names = FALSE)
write.csv(res_df, file.path(out_dir, "rmse_results.csv"), row.names = FALSE)
# ---- 7. Summary across patches ----------------------------------------------
corr_df <- res_df[res_df$variant == "corrected_m", ]
naive_df <- res_df[res_df$variant == "naive_full", ]
summary_df <- aggregate(rmse ~ m, data = corr_df,
FUN = function(x) c(mean = mean(x),
median = median(x),
sd = sd(x)))
summary_df <- do.call(data.frame, summary_df)
names(summary_df) <- c("m", "rmse_mean", "rmse_median", "rmse_sd")
rmse_naive_mean   <- mean(naive_df$rmse)
rmse_naive_median <- median(naive_df$rmse)
cat("\n--- Mean / median RMSE across patches ---\n")
print(summary_df, row.names = FALSE)
cat(sprintf("\nNaive (all lags): mean RMSE = %.4f, median RMSE = %.4f\n",
rmse_naive_mean, rmse_naive_median))
p1 <- ggplot(corr_df, aes(x = m, y = rmse, colour = patch)) +
geom_line(linewidth = 0.9) +
geom_point(size = 2) +
geom_hline(data = naive_df,
aes(yintercept = rmse, colour = patch),
linetype = "dashed", linewidth = 0.5) +
scale_x_continuous(breaks = m_grid) +
labs(
x        = "Truncation parameter m",
y        = "Prediction RMSE",
colour   = "Patch",
title    = "Kriging RMSE per patch",
subtitle = sprintf("Image: %s  |  patch %dx%d  |  hidden block %dx%d  |  dashed = naive (all lags)",
img_name, patch_n1, patch_n2, pred_blk, pred_blk)
) +
theme_minimal(base_size = 12)
ggsave(file.path(out_dir, "rmse_per_patch.pdf"), p1, width = 9, height = 6)
print(p1)
