geom_line(linewidth = 0.9) +
geom_point(size = 2) +
geom_hline(data = naive_df,
aes(yintercept = rmse, colour = patch),
linetype = "dashed", linewidth = 0.5) +
scale_x_continuous(breaks = m_grid) +
labs(
x        = "Truncation parameter m",
y        = "Prediction RMSE",
colour   = "Patch",
title    = "Kriging RMSE per patch",
subtitle = sprintf("Image: %s  |  patch %dx%d  |  hidden block %dx%d  |  dashed = naive (all lags)",
